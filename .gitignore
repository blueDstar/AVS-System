# ROS2 build artifacts
ros2_ws/build/
ros2_ws/install/
ros2_ws/log/
build/
install/
log/

# Python cache
__pycache__/
*.pyc
*.pyo
*.so

# Large/generated files - ignore by default
*.avi
*.mov
*.mkv
*.bag
*.db3
*.tar
*.zip

# Ignore mp4 by default, but allow demo drive videos
*.mp4
!ros2_ws/demo_data/
!ros2_ws/demo_data/drive_record/
!ros2_ws/demo_data/drive_record/videos/
!ros2_ws/demo_data/drive_record/videos/*.mp4

# Local/system
.vscode/
.cache/
.DS_Store
core
